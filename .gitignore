# ============================================================
# NIDS Project .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/

# --- Virtual Environment ---
venv/
.venv/
env/

# --- Data folder: keep structure, ignore all files ---
# Recursively ignore all files inside data/ but keep folder structure
data/**/*
!data/**/.gitkeep

# --- Reports: keep structure, ignore all files ---
reports/*
!reports/.gitkeep

# --- Results: keep structure, ignore all files ---
results/*
!results/.gitkeep

# --- Temp/simul: keep structure, ignore all files ---
temp/simul/*
!temp/simul/.gitkeep

# --- Trained model all: keep structure, ignore all files ---
trained_models/trained_model_all/*
!trained_models/trained_model_all/.gitkeep

# --- Other temp files ---
temp/
.temp/

# --- IDE / Editor ---
.idea/
.vscode/
*.iml
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini
